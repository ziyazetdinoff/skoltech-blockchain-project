{
  "name": "dca-mvp-sepolia",
  "version": "1.0.0",
  "private": true,
  "description": "Educational DCA MVP for Ethereum Sepolia with Hardhat, Telegram bot and executor service.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "hardhat clean",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "bot": "tsx bot/index.ts",
    "executor": "tsx executor/index.ts",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "seed:sepolia": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^22.13.10",
    "hardhat": "^2.22.19",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
